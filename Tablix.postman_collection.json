{
  "info": {
    "name": "Tablix",
    "description": "Tablix REST API - SQLite-persisted database discovery, model management, context, and chat platform. Set baseUrl to your Tablix server and apiKey to a value from tablix.json ApiKeys.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9100"
    },
    {
      "key": "apiKey",
      "value": "tablixadmin"
    },
    {
      "key": "databaseId",
      "value": "db_sample_sqlite"
    },
    {
      "key": "providerId",
      "value": "provider_ollama_local"
    },
    {
      "key": "tableId",
      "value": "tbl_db_sample_sqlite_main_users"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{apiKey}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Returns server name, version, start time, and uptime. No authentication required."
          }
        },
        {
          "name": "Health Check (HEAD)",
          "request": {
            "method": "HEAD",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Lightweight health check. Returns 200 OK with no body. No authentication required."
          }
        }
      ]
    },
    {
      "name": "Setup",
      "item": [
        {
          "name": "Get Setup State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/setup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "setup"
              ]
            },
            "description": "Read first-run setup state and whether the dashboard wizard should be shown."
          }
        },
        {
          "name": "Update Setup State",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/setup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "setup"
              ]
            },
            "description": "Save first-run setup progress.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Status\": \"InProgress\",\n  \"CurrentStep\": \"database-context\",\n  \"SelectedProviderId\": \"{{providerId}}\",\n  \"SelectedDatabaseId\": \"{{databaseId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Complete Setup",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/setup/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "setup",
                "complete"
              ]
            },
            "description": "Mark first-run setup complete."
          }
        },
        {
          "name": "Dismiss Setup",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/setup/dismiss",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "setup",
                "dismiss"
              ]
            },
            "description": "Dismiss first-run setup without marking setup complete."
          }
        }
      ]
    },
    {
      "name": "Models",
      "item": [
        {
          "name": "List Models",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/model?maxResults=100&skip=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model"
              ],
              "query": [
                {
                  "key": "maxResults",
                  "value": "100"
                },
                {
                  "key": "skip",
                  "value": "0"
                }
              ]
            },
            "description": "List persisted model providers with pagination and redacted secrets."
          }
        },
        {
          "name": "Get Model",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/model/{{providerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model",
                "{{providerId}}"
              ]
            },
            "description": "Read one redacted persisted model provider."
          }
        },
        {
          "name": "Create Model",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/model",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model"
              ]
            },
            "description": "Create a persisted model provider. ApiKey is accepted but never returned by read APIs.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Id\": \"{{providerId}}\",\n  \"Name\": \"Local Ollama\",\n  \"Type\": \"Ollama\",\n  \"Endpoint\": \"http://ollama:11434\",\n  \"ApiKey\": \"\",\n  \"ClearApiKey\": false,\n  \"Model\": \"gemma3:4b\",\n  \"SystemPrompt\": null,\n  \"Enabled\": true,\n  \"DefaultStreaming\": true,\n  \"SupportsNativeToolCalls\": true,\n  \"UseNativeToolCalls\": false,\n  \"SupportsStrictJson\": false,\n  \"ToolCapabilityNote\": \"Enable native tools after validating this provider/model emits tool calls reliably.\",\n  \"Temperature\": 0.2,\n  \"TopP\": null,\n  \"MaxTokens\": 4096,\n  \"RequestTimeoutMs\": 120000,\n  \"MaxConcurrentRequests\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Update Model",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/model/{{providerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model",
                "{{providerId}}"
              ]
            },
            "description": "Update a persisted model provider. Leave ApiKey empty to preserve it or set ClearApiKey to true to remove it.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Id\": \"{{providerId}}\",\n  \"Name\": \"Local Ollama\",\n  \"Type\": \"Ollama\",\n  \"Endpoint\": \"http://ollama:11434\",\n  \"ApiKey\": \"\",\n  \"ClearApiKey\": false,\n  \"Model\": \"gemma3:4b\",\n  \"SystemPrompt\": null,\n  \"Enabled\": true,\n  \"DefaultStreaming\": true,\n  \"SupportsNativeToolCalls\": true,\n  \"UseNativeToolCalls\": false,\n  \"SupportsStrictJson\": false,\n  \"ToolCapabilityNote\": \"Enable native tools after validating this provider/model emits tool calls reliably.\",\n  \"Temperature\": 0.2,\n  \"TopP\": null,\n  \"MaxTokens\": 4096,\n  \"RequestTimeoutMs\": 120000,\n  \"MaxConcurrentRequests\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete Model",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/model/{{providerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model",
                "{{providerId}}"
              ]
            },
            "description": "Delete a persisted model provider."
          }
        },
        {
          "name": "Test Unsaved Model",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/model/test",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model",
                "test"
              ]
            },
            "description": "Test unsaved model provider settings without persisting them.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Provider\": {\n    \"Id\": \"{{providerId}}\",\n    \"Name\": \"Local Ollama\",\n    \"Type\": \"Ollama\",\n    \"Endpoint\": \"http://ollama:11434\",\n    \"ApiKey\": \"\",\n    \"ClearApiKey\": false,\n    \"Model\": \"gemma3:4b\",\n    \"SystemPrompt\": null,\n    \"Enabled\": true,\n    \"DefaultStreaming\": true,\n    \"SupportsNativeToolCalls\": true,\n    \"UseNativeToolCalls\": false,\n    \"SupportsStrictJson\": false,\n    \"ToolCapabilityNote\": \"Enable native tools after validating this provider/model emits tool calls reliably.\",\n    \"Temperature\": 0.2,\n    \"TopP\": null,\n    \"MaxTokens\": 4096,\n    \"RequestTimeoutMs\": 120000,\n    \"MaxConcurrentRequests\": 1\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Test Saved Model",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/model/{{providerId}}/test",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "model",
                "{{providerId}}",
                "test"
              ]
            },
            "description": "Test a saved model provider."
          }
        }
      ]
    },
    {
      "name": "Database CRUD",
      "item": [
        {
          "name": "List Databases",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database?maxResults=100&skip=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database"
              ],
              "query": [
                {
                  "key": "maxResults",
                  "value": "100",
                  "description": "Maximum results to return (1-1000, default 100)"
                },
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of records to skip (default 0)"
                },
                {
                  "key": "filter",
                  "value": "",
                  "description": "Filter by database ID or name (case-insensitive)",
                  "disabled": true
                }
              ]
            },
            "description": "List all configured databases with pagination and optional filtering."
          }
        },
        {
          "name": "Get Database",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}"
              ]
            },
            "description": "Get database details including connection settings, schema geometry (tables, columns, PKs, FKs, indexes), and crawl status."
          }
        },
        {
          "name": "Add Database",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Id\": \"db_new_database\",\n  \"Name\": \"My New Database\",\n  \"Type\": \"Postgresql\",\n  \"Hostname\": \"localhost\",\n  \"Port\": 5432,\n  \"User\": \"postgres\",\n  \"Password\": \"secret\",\n  \"DatabaseName\": \"mydb\",\n  \"Schema\": \"public\",\n  \"AllowedQueries\": [\"SELECT\"],\n  \"Context\": \"Description of this database for AI agents...\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/database",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database"
              ]
            },
            "description": "Add a new database entry. An initial schema crawl is triggered automatically. Returns 201 Created on success, 409 Conflict if the ID already exists."
          }
        },
        {
          "name": "Update Database",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Name\": \"Updated Name\",\n  \"Type\": \"Postgresql\",\n  \"Hostname\": \"localhost\",\n  \"Port\": 5432,\n  \"User\": \"postgres\",\n  \"Password\": \"secret\",\n  \"DatabaseName\": \"mydb\",\n  \"Schema\": \"public\",\n  \"AllowedQueries\": [\"SELECT\", \"INSERT\", \"UPDATE\", \"DELETE\"],\n  \"Context\": \"Updated context description...\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}"
              ]
            },
            "description": "Update an existing database entry. The ID in the path is used; any ID in the body is ignored. The crawl cache is updated immediately."
          }
        },
        {
          "name": "Test Unsaved Database",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/database/test",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "test"
              ]
            },
            "description": "Test unsaved database settings without persisting them.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Database\": {\n    \"Id\": \"db_candidate\",\n    \"Name\": \"Candidate SQLite\",\n    \"Type\": \"Sqlite\",\n    \"Filename\": \"./database.db\",\n    \"Schema\": \"main\",\n    \"AllowedQueries\": [\"SELECT\"]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Test Saved Database",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/test",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "test"
              ]
            },
            "description": "Test a saved database connection."
          }
        },
        {
          "name": "Delete Database",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}"
              ]
            },
            "description": "Delete a database entry and remove it from the crawl cache. Returns 204 No Content on success."
          }
        }
      ]
    },
    {
      "name": "Context",
      "item": [
        {
          "name": "Get Database Context",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}"
              ]
            },
            "description": "Read database-level context through the database detail endpoint. MCP equivalent: tablix_get_database_context."
          }
        },
        {
          "name": "Update Database Context",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Context\": \"Analyzed database context for AI agents...\",\n  \"Mode\": \"replace\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/context",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "context"
              ]
            },
            "description": "Replace or append database-level context. MCP equivalents: tablix_update_database_context or tablix_update_context with scope Database."
          }
        },
        {
          "name": "Build Database Context",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ProviderId\": \"{{providerId}}\",\n  \"Prompt\": \"Analyze the last successful crawl and produce concise durable context for future database chat and MCP usage. Include major entities, relationships, naming conventions, join paths, and safe query guidance. Do not include credentials, secrets, or raw result rows.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/context/build",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "context",
                "build"
              ]
            },
            "description": "Generate database-level context with a configured model provider and persist it. MCP can later read it with tablix_get_database_context."
          }
        },
        {
          "name": "List Table Contexts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/table-context",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "table-context"
              ]
            },
            "description": "List persisted table-level context records. MCP equivalent: tablix_get_table_context without table selectors."
          }
        },
        {
          "name": "Get Table Context",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/table-context/{{tableId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "table-context",
                "{{tableId}}"
              ]
            },
            "description": "Read one table-level context record. MCP equivalent: tablix_get_table_context with tableId or tableName."
          }
        },
        {
          "name": "Update Table Context",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/table-context/{{tableId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "table-context",
                "{{tableId}}"
              ]
            },
            "description": "Replace or append table-level context. MCP equivalents: tablix_update_table_context or tablix_update_context with scope Table.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Context\": \"Table-specific context, important columns, joins, filters, and caveats.\",\n  \"Mode\": \"replace\",\n  \"Source\": \"user\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Build Table Contexts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ProviderId\": \"{{providerId}}\",\n  \"Prompt\": \"For each selected table, produce concise durable context with purpose, key columns, relationships, join paths, common filters, and caveats. Do not include credentials, secrets, or raw result rows.\",\n  \"TableIds\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/table-context/build",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "table-context",
                "build"
              ]
            },
            "description": "Generate table-level context for all or selected tables using a configured model provider."
          }
        },
        {
          "name": "Build One Table Context",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ProviderId\": \"{{providerId}}\",\n  \"Prompt\": \"Produce concise durable context for this table with key columns, relationships, join paths, and common filters.\",\n  \"TableIds\": [\"{{tableId}}\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/table-context/{{tableId}}/build",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "table-context",
                "{{tableId}}",
                "build"
              ]
            },
            "description": "Generate table-level context for one table using a configured model provider."
          }
        }
      ]
    },
    {
      "name": "Schema Discovery",
      "item": [
        {
          "name": "Re-Crawl Database",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/crawl",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "crawl"
              ]
            },
            "description": "Re-crawl the database schema. Discovers tables, columns, primary keys, foreign keys, and indexes. Returns the updated DatabaseDetail. If the crawl fails (unreachable host, bad credentials), the response still returns 200 with IsCrawled: false and a CrawlError message."
          }
        },
        {
          "name": "Re-Crawl Database (Stream)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/crawl/stream",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "crawl",
                "stream"
              ]
            },
            "description": "Re-crawl the database schema and stream status as server-sent events. Emits started, progress, and one terminal completed or failed event. Terminal events include table counts and the final DatabaseDetail."
          }
        },
        {
          "name": "List Tables",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/database/{{databaseId}}/tables?maxResults=100&skip=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "database",
                "{{databaseId}}",
                "tables"
              ],
              "query": [
                {
                  "key": "maxResults",
                  "value": "100",
                  "description": "Maximum tables to return (1-1000, default 100)"
                },
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of tables to skip (default 0)"
                },
                {
                  "key": "filter",
                  "value": "",
                  "description": "Filter by table or schema name",
                  "disabled": true
                },
